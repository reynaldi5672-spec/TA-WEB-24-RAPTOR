// Prisma schema for website informasi wisata hits Bandar Lampung.
// Model ini cocok untuk data destinasi, komentar pengunjung, dan admin.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DestinasiKategori {
  pantai
  wisata_alam
  wisata_kota
  heritage
  kuliner
  adventure
}

enum Role {
  admin
  editor
  guest
}

model Destinasi {
  id          Int                 @id @default(autoincrement())
  nama        String
  lokasi      String
  deskripsi   String
  gambar_url  String?
  rating      Float               @default(0)
  is_viral    Boolean             @default(false)
  kategori    DestinasiKategori   @default(pantai)
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  komentar    Komentar[]
}

model Komentar {
  id            Int       @id @default(autoincrement())
  destinasi     Destinasi @relation(fields: [destinasi_id], references: [id])
  destinasi_id  Int
  nama_user     String
  isi_komentar  String
  rating        Int
  created_at    DateTime  @default(now())

  @@index([destinasi_id])
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  password    String
  role        Role     @default(admin)
  created_at  DateTime @default(now())
}
