generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model destinasi {
  id         Int        @id @default(autoincrement())
  nama       String     @db.VarChar(255)
  lokasi     String     @db.VarChar(255)
  deskripsi  String
  gambar_url String
  rating     Decimal    @default(4.5) @db.Decimal(2, 1)
  is_viral   Boolean?   @default(false)
  kategori   String?    @default("pantai") @db.VarChar(50)
  komentar   komentar[]
}

model komentar {
  id           Int       @id @default(autoincrement())
  destinasi_id Int
  nama_user    String    @default("Anonim") @db.VarChar(100)
  isi_komentar String
  rating       Int
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  destinasi    destinasi @relation(fields: [destinasi_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_destinasi")
}

model user {
  id         Int       @id @default(autoincrement())
  username   String    @unique @db.VarChar(50)
  password   String
  role       String?   @default("admin") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("users")
}
