generator client {
  provider   = "prisma-client-js"
  engineType = "library" // <-- 1. WAJIB DIKASIH INI JIRR! Biar dia pake engine Node.js lokal, gak nyasar ke cloud!
}

datasource db {
  provider = "postgresql" // 2. Biarin kosongan gini gapapa karena koneksi aslinya udah kita kunci di file prisma.config.ts!
}

model destinasi {
  id         Int        @id @default(autoincrement())
  nama       String     @db.VarChar(255)
  lokasi     String     @db.VarChar(255)
  deskripsi  String
  gambar_url String
  rating     Decimal    @default(4.5) @db.Decimal(2, 1)
  is_viral   Boolean?   @default(false)
  kategori   String?    @default("pantai") @db.VarChar(50)
  komentar   komentar[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model komentar {
  id           Int       @id @default(autoincrement())
  destinasi_id Int
  nama_user    String    @default("Anonim") @db.VarChar(100)
  isi_komentar String
  rating       Int
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  destinasi    destinasi @relation(fields: [destinasi_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_destinasi")
}

model users {
  id         Int       @id @default(autoincrement())
  username   String    @unique @db.VarChar(50)
  password   String
  role       String?   @default("admin") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}