// Prisma schema for website informasi wisata hits Bandar Lampung.
// Model ini cocok untuk data destinasi, komentar pengunjung, dan admin.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DestinasiKategori {
  pantai
  wisata_alam
  wisata_kota
  heritage
  kuliner
  adventure
}

enum Role {
  admin
  editor
  guest
}

